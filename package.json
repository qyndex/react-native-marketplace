    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "jest-expo": "^47.0.1",
    "prettier": "^3.0.0",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.1.3"
  },
